{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packet.net/schema/sdl-subroutines.schema.json",
  "title": "SDL subroutines page (figc4.7)",
  "description": "Machine-readable transcription of an SDL subroutines figure from the AX.25 spec. Unlike a state-machine page (sdl-machine.schema.json), a subroutines page describes function bodies: each entry has a name, optional decisions, and one or more `paths` corresponding to combinations of decision-branch outcomes. Subroutines are invoked by `kind: subroutine` action steps in state-machine pages; the codegen produces one C# method per subroutine, registered into DefaultSubroutineRegistry.",
  "type": "object",
  "required": ["machine", "source", "subroutines"],
  "additionalProperties": false,
  "properties": {
    "machine": {
      "type": "string",
      "enum": [
        "data_link",
        "link_mux",
        "mgmt_data_link",
        "simplex_phy",
        "duplex_phy",
        "segmenter",
        "reassembler"
      ],
      "description": "Which spec state machine these subroutines belong to."
    },
    "source": {
      "type": "object",
      "required": ["spec", "figure"],
      "additionalProperties": false,
      "properties": {
        "spec":   { "type": "string" },
        "figure": { "type": "string" },
        "url":    { "type": "string", "format": "uri" }
      }
    },
    "pinned_refs": {
      "type": "object",
      "description": "Per-source git ref pins for cross-reference citations. Same shape as on state-machine pages.",
      "additionalProperties": {
        "type": "object",
        "required": ["repo", "commit"],
        "additionalProperties": false,
        "properties": {
          "repo":   { "type": "string", "format": "uri" },
          "commit": { "type": "string" }
        }
      }
    },
    "subroutines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "paths"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z][A-Za-z0-9_]*$",
            "description": "Canonical PascalCase_With_Underscores subroutine name (e.g. 'Establish_Data_Link', 'Set_Version_2_0'). Same key used by `kind: subroutine` action references and by DefaultSubroutineRegistry."
          },
          "notes": {
            "type": "string",
            "description": "Free-form notes about the subroutine — typically where it's called from and any non-obvious figure quirks."
          },
          "variables": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Documentation-only list of context variables the subroutine reads / writes."
          },
          "references": {
            "type": "array",
            "description": "Subroutine-level cross-references — typically per-implementation citations of where this subroutine's logic lives in each of the canonical reference codebases. Same shape as a transition's references.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "source":   { "type": "string" },
                "cite":     { "type": "string" },
                "quote":    { "type": "string" },
                "path":     { "type": "string" },
                "function": { "type": "string" },
                "line":     { "type": "integer", "minimum": 1 },
                "note":     { "type": "string" },
                "omit":     { "type": "boolean" },
                "reason":   { "type": "string" }
              }
            }
          },
          "decisions": {
            "type": "array",
            "description": "Catalogue of decision diamonds in this subroutine. Same shape as on state-machine pages.",
            "items": {
              "type": "object",
              "required": ["id", "question", "predicate"],
              "additionalProperties": false,
              "properties": {
                "id":        { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
                "question":  { "type": "string", "description": "Exact wording from the figure." },
                "predicate": { "type": "string", "description": "Canonical boolean expression evaluated by GuardEvaluator." }
              }
            }
          },
          "paths": {
            "type": "array",
            "minItems": 1,
            "description": "One entry per combination of decision branches through the subroutine. For a decision-free subroutine there's a single path; for a chain of N binary diamonds, up to 2^N paths.",
            "items": {
              "type": "object",
              "required": ["id", "path"],
              "additionalProperties": false,
              "properties": {
                "id":    { "type": "string", "pattern": "^t[0-9]{2}_[a-z0-9_]+$" },
                "path":  {
                  "type": "array",
                  "description": "Ordered interleaving of decision-branch and action steps describing one execution path through the subroutine. Reuses the state-machine page step types: action, decision, loop_while.",
                  "items": {
                    "oneOf": [
                      {
                        "type": "object",
                        "required": ["decision", "branch"],
                        "additionalProperties": false,
                        "properties": {
                          "decision": { "type": "string" },
                          "branch":   { "type": "string", "enum": ["Yes", "No"] }
                        }
                      },
                      {
                        "type": "object",
                        "required": ["action", "kind"],
                        "additionalProperties": false,
                        "properties": {
                          "action": { "type": "string" },
                          "kind":   {
                            "type": "string",
                            "enum": ["signal_upper", "signal_lower", "processing", "subroutine", "internal_out"]
                          }
                        }
                      },
                      {
                        "type": "object",
                        "required": ["loop_while", "body"],
                        "additionalProperties": false,
                        "properties": {
                          "loop_while": { "type": "string" },
                          "body": {
                            "type": "array",
                            "minItems": 1
                          }
                        }
                      }
                    ]
                  }
                },
                "notes": { "type": "string" },
                "references": {
                  "type": "array",
                  "description": "Cross-reference citations for this path. Same shape as on state-machine pages.",
                  "items": {
                    "type": "object",
                    "required": ["source"],
                    "additionalProperties": false,
                    "properties": {
                      "source":   { "type": "string" },
                      "cite":     { "type": "string" },
                      "quote":    { "type": "string" },
                      "path":     { "type": "string" },
                      "function": { "type": "string" },
                      "line":     { "type": "integer", "minimum": 1 },
                      "note":     { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
