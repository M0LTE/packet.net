<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- The deployable node binary. -->
    <OutputType>Exe</OutputType>
    <AssemblyName>packetnet</AssemblyName>
    <RootNamespace>Packet.Node</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- The host shell is thin: all node logic lives in Packet.Node.Core. -->
    <ProjectReference Include="..\Packet.Node.Core\Packet.Node.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Expose internal API helpers (e.g. the session-id split, a load-bearing contract)
         to the node test project for focused unit tests alongside the WAF integration ones. -->
    <InternalsVisibleTo Include="Packet.Node.Tests" />
  </ItemGroup>

</Project>
