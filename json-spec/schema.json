{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packet.net/sdl/schema.json",
  "title": "ax25sdl",
  "description": "Resolved SDL IR for the AX.25 v2.2 specification. Each *.g.json conforms to statePage, subroutinesPage, or indexPage.",
  "$defs": {
    "actionKind": {
      "type": "string",
      "enum": [
        "signal_upper",
        "signal_lower",
        "processing",
        "subroutine",
        "internal_out"
      ]
    },
    "actionStep": {
      "type": "object",
      "required": [
        "verb",
        "kind"
      ],
      "additionalProperties": false,
      "properties": {
        "verb": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/actionKind"
        }
      }
    },
    "loopRange": {
      "type": "object",
      "required": [
        "start",
        "length",
        "predicate"
      ],
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "length": {
          "type": "integer",
          "minimum": 0
        },
        "predicate": {
          "type": "string"
        }
      }
    },
    "implementationReference": {
      "type": "object",
      "required": [
        "source",
        "cite",
        "quote",
        "path",
        "function",
        "line",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string"
        },
        "cite": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "function": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 0
        },
        "note": {
          "type": "string"
        }
      }
    },
    "source": {
      "type": "object",
      "required": [
        "spec",
        "figure",
        "url"
      ],
      "additionalProperties": false,
      "properties": {
        "spec": {
          "type": "string"
        },
        "figure": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    },
    "transitionSpec": {
      "type": "object",
      "required": [
        "id",
        "from",
        "on",
        "guard",
        "actions",
        "next",
        "notes",
        "references",
        "loops"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "on": {
          "type": "string"
        },
        "guard": {
          "type": "string"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/actionStep"
          }
        },
        "next": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/implementationReference"
          }
        },
        "loops": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/loopRange"
          }
        }
      }
    },
    "subroutinePath": {
      "type": "object",
      "required": [
        "id",
        "guard",
        "actions",
        "notes",
        "references",
        "loops"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "guard": {
          "type": "string"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/actionStep"
          }
        },
        "notes": {
          "type": "string"
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/implementationReference"
          }
        },
        "loops": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/loopRange"
          }
        }
      }
    },
    "subroutineSpec": {
      "type": "object",
      "required": [
        "name",
        "paths",
        "notes",
        "references"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subroutinePath"
          }
        },
        "notes": {
          "type": "string"
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/implementationReference"
          }
        }
      }
    },
    "statePage": {
      "type": "object",
      "required": [
        "kind",
        "machine",
        "state",
        "source",
        "transitions"
      ],
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "type": "string"
        },
        "kind": {
          "const": "state"
        },
        "machine": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transitionSpec"
          }
        }
      }
    },
    "subroutinesPage": {
      "type": "object",
      "required": [
        "kind",
        "machine",
        "source",
        "subroutines"
      ],
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "type": "string"
        },
        "kind": {
          "const": "subroutines"
        },
        "machine": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "subroutines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subroutineSpec"
          }
        }
      }
    },
    "indexEntry": {
      "type": "object",
      "required": [
        "file",
        "kind",
        "machine",
        "figure"
      ],
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "state",
            "subroutines"
          ]
        },
        "machine": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "figure": {
          "type": "string"
        }
      }
    },
    "indexPage": {
      "type": "object",
      "required": [
        "kind",
        "pages"
      ],
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "type": "string"
        },
        "kind": {
          "const": "index"
        },
        "pages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/indexEntry"
          }
        }
      }
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/statePage"
    },
    {
      "$ref": "#/$defs/subroutinesPage"
    },
    {
      "$ref": "#/$defs/indexPage"
    }
  ]
}
